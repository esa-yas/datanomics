{
  "manifest_version": 3,
  "name": "Datanomics Reply Assistant",
  "version": "1.0.0",
  "description": "AI recruiter reply drafts for LinkedIn, Gmail, and job boards — powered by Job Search OS",
  "permissions": ["storage", "activeTab", "scripting", "sidePanel", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://mail.google.com/*",
    "https://*.indeed.com/*",
    "https://*.supabase.co/*",
    "http://localhost:5001/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Datanomics Reply Assistant"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content/gmail.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.indeed.com/*"],
      "js": ["content/indeed.js"],
      "run_at": "document_idle"
    }
  ]
}
