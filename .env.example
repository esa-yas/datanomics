# =============================================================================
# Datanomics Job Search OS — environment template
# =============================================================================
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# Never commit .env (secrets). .env.example is safe to commit.
# =============================================================================

# -----------------------------------------------------------------------------
# App / Vite (required for `pnpm --filter @workspace/datanomics run dev`)
# -----------------------------------------------------------------------------
PORT=5173
BASE_PATH=/

# -----------------------------------------------------------------------------
# Supabase (required for auth + data)
# Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# -----------------------------------------------------------------------------
# AI — resume tailor, JD parse, recruiter replies (optional until you use AI)
# Default: GPT 5.5 via Freemodel (Codex-compatible proxy)
# Get key: https://freemodel.dev — same key as ~/.codex/auth.json OPENAI_API_KEY
# -----------------------------------------------------------------------------
VITE_AI_PROVIDER=openai
# Server-side key (used by Vite proxy + api-server — never exposed to the browser)
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.freemodel.dev
# Browser calls same-origin proxy to avoid CORS
VITE_OPENAI_BASE_URL=/api/ai
VITE_OPENAI_MODEL=gpt-5.5
VITE_OPENAI_REASONING_EFFORT=medium

# Optional: Google Gemini instead of OpenAI
# VITE_AI_PROVIDER=gemini
# VITE_GEMINI_API_KEY=your-gemini-api-key
# VITE_GEMINI_MODEL=gemini-flash-latest

# VITE_ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# API server scaffold (optional — health check only today)
# Supabase connection string OR local Postgres
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/datanomics
LOG_LEVEL=info

# API server (Gmail sync OAuth — separate port from Vite)
# PORT=5001
API_SERVER_URL=http://localhost:5001
VITE_API_URL=http://localhost:5001
# Chrome extension — api-server base URL (use production URL when deployed)
VITE_EXTENSION_API_URL=http://localhost:5001

# -----------------------------------------------------------------------------
# Gmail Apply Label Sync (api-server — tokens never exposed to browser)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_TOKEN_ENCRYPTION_KEY=generate-a-long-random-secret-at-least-32-chars
GMAIL_OAUTH_REDIRECT_URI=http://localhost:5001/api/gmail/oauth/callback
GMAIL_CONNECT_LINK_BASE_URL=http://localhost:5173
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key
# GMAIL_CRON_SECRET=your-cron-secret
# GMAIL_AUTO_SYNC_INTERVAL_MINUTES=15
# GMAIL_SYNC_CONCURRENCY=20

# -----------------------------------------------------------------------------
# AI Job Research (web search + ranking — api-server)
# Requires TAVILY_API_KEY (https://tavily.com) OR SERPER_API_KEY (https://serper.dev)
# OPENAI_API_KEY is used to rank and parse search results into job recommendations
# If Freemodel/OpenAI is down, set JOB_RESEARCH_AI_PROVIDER=gemini (uses VITE_GEMINI_API_KEY)
# -----------------------------------------------------------------------------
# TAVILY_API_KEY=tvly-your-key
# SERPER_API_KEY=your-serper-key
# JOB_RESEARCH_AI_PROVIDER=auto
# JOB_RESEARCH_MODEL=gpt-5.5
# JOB_RESEARCH_GEMINI_MODEL=gemini-2.0-flash
# JOB_RESEARCH_MAX_RESULTS=30
# JOB_RESEARCH_AUTO_INTERVAL_HOURS=24
# JOB_RESEARCH_CRON_SECRET=your-cron-secret

# -----------------------------------------------------------------------------
# AI Voice Interview Practice (ElevenLabs hosted agent — no tunnel required)
# -----------------------------------------------------------------------------
# ELEVENLABS_API_KEY=your-elevenlabs-api-key
# ELEVENLABS_INTERVIEW_AGENT_ID=agent_...   # optional — auto-created on first boot
# ELEVENLABS_AGENT_LLM=gemini-2.0-flash
# GEMINI_API_KEY uses VITE_GEMINI_API_KEY for post-interview feedback scoring
# GEMINI_FEEDBACK_MODEL=gemini-2.5-flash
# INTERVIEW_LINK_BASE_URL=http://localhost:5173
# INTERVIEW_LINK_TTL_DAYS=7
